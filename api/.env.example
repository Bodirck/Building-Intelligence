# Copy this file to api/.env and fill in your key. api/.env is git-ignored.
# Without a key, the defect sheet falls back to a deterministic generator (no LLM).
ANTHROPIC_API_KEY=sk-ant-your-key-here
BI_LLM_MODEL=claude-sonnet-4-6

# Optional path overrides (defaults resolve relative to the repo root):
# BI_DB_PATH=./data/app.db
# BI_MODEL_PATH=./models/crack_mobilenet.pt
